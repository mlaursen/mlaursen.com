{
  "name": "mlaursen.com",
  "type": "module",
  "homepage": "https://mlaursen.com",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "typecheck": "tsgo --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest app",
    "test-playwright": "playwright test",
    "playwright-report": "playwright show-report",
    "playwright-install": "playwright install --with-deps",
    "lint": "eslint \"**/*.{ts,tsx,js,jsx}\"",
    "lint-fix": "pnpm lint --fix",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start-static": "serve -p 3000 ./out"
  },
  "repository": "git@github.com:mlaursen/mlaursen.com.git",
  "author": "Mikkel Laursen <mlaursen03@gmail.com>",
  "dependencies": {
    "@react-md/core": "7.0.7",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@jest/types": "^30.4.1",
    "@mlaursen/eslint-config": "^12.0.11",
    "@next/eslint-plugin-next": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@swc/types": "^0.1.27",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "beta",
    "eslint": "^9.39.3",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-watch-typeahead": "^3.0.1",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "sass-embedded": "^1.100.0",
    "serve": "^14.2.6",
    "typescript": "npm:@typescript/typescript6@^6.0.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,scss,js,jsx,md,yml,json}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.0"
  },
  "engineStrict": true
}
